# Service role — determines which env vars are validated
# Values: agent | weather-mcp | flight-mcp
SERVICE_ROLE=agent

# Shared
PORT=3000
REDIS_URL=redis://localhost:6379

# Agent only
OPENAI_API_KEY=sk-your-openai-key
LANGSMITH_API_KEY=ls-your-langsmith-key
OAUTH_SECRET=your-oauth-secret-min-32-chars-long
WEATHER_MCP_URL=http://localhost:3001/mcp
FLIGHT_MCP_URL=http://localhost:3002/mcp
RATE_LIMITER_POINTS=200

# Weather MCP only
WEATHERAPI_KEY=your-weatherapi-key

# Flight MCP only
FLIGHT_PROVIDER=mock
FLIGHTAWARE_API_KEY=your-flightaware-key
