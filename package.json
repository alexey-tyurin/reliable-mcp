{
  "name": "mcp-chatbot",
  "version": "1.0.0",
  "description": "Production-ready chatbot using MCP servers, LangGraphJS agent orchestration, and comprehensive reliability patterns",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:prod": "tsc -p tsconfig.prod.json && rm -rf dist/chaos",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:chaos": "CHAOS_ENABLED=true vitest run tests/chaos/",
    "chaos:status": "CHAOS_ENABLED=true tsx src/chaos/cli.ts status",
    "chaos:clear": "CHAOS_ENABLED=true tsx src/chaos/cli.ts clear-all",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "eval:quick": "tsx tests/eval/run-eval.ts --quick",
    "eval:resilience": "tsx tests/eval/run-eval.ts --resilience",
    "eval": "tsx tests/eval/run-eval.ts",
    "predeploy": "tsc --noEmit && npm run lint && npm run test && npm run eval",
    "typecheck": "tsc --noEmit",
    "dev:agent": "SERVICE_ROLE=agent PORT=3000 tsx --env-file=.env src/entrypoints/agent.ts",
    "dev:weather-mcp": "SERVICE_ROLE=weather-mcp PORT=3001 tsx --env-file=.env src/entrypoints/weather-mcp.ts",
    "dev:flight-mcp": "SERVICE_ROLE=flight-mcp PORT=3002 tsx --env-file=.env src/entrypoints/flight-mcp.ts"
  },
  "dependencies": {
    "@langchain/core": "0.3.80",
    "@langchain/langgraph": "0.2.60",
    "@langchain/openai": "0.4.9",
    "@modelcontextprotocol/sdk": "1.27.1",
    "cors": "2.8.6",
    "express": "4.22.1",
    "helmet": "8.1.0",
    "ioredis": "5.10.0",
    "jose": "6.1.3",
    "langsmith": "0.3.87",
    "openai": "4.104.0",
    "opossum": "9.0.0",
    "pino": "10.3.1",
    "rate-limiter-flexible": "9.1.1",
    "zod": "3.24.2",
    "zod-to-json-schema": "3.24.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "4.17.25",
    "@types/node": "22.19.13",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "9.39.3",
    "eslint-plugin-security": "4.0.0",
    "ts-node-dev": "2.0.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
